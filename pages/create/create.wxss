/* pages/create/create.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #667eea 0%, #764ba2 100%);
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── 品牌标题 ── */
.header {
  text-align: center;
  padding: 70rpx 0 40rpx;
}

.title-art {
  display: block;
  width: 360rpx;
  margin: 0 auto 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── 个人信息栏 ── */
.profile-bar {
  margin-bottom: 40rpx;
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.avatar-btn {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 1;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.profile-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  padding-left: 24rpx;
  height: 28rpx;
  line-height: 28rpx;
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.35);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #fff;
  box-sizing: border-box;
}

.nickname-input::placeholder {
  color: rgba(255,255,255,0.55);
}

/* ── 白色主卡片 ── */
.card {
  width: calc(100% - 60rpx);
  margin: 0 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.12);
}

.section {
  margin-bottom: 0;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* ── 人数选择器 ── */
.selector-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.count-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.count-row:last-child {
  margin-bottom: 0;
}

.count-btn {
  width: 100rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #f5f6fa;
  color: #555;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102,126,234,0.35);
}

.more-row {
  margin-top: 12rpx;
  margin-bottom: 28rpx;
}

.more-text {
  font-size: 24rpx;
  color: #667eea;
}

/* ── 创建按钮 ── */
.btn-create {
  margin-top: 28rpx;
  width: 100%;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 92rpx;
  height: 92rpx;
  padding: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-create::after {
  border: none;
}

.btn-create[disabled] {
  opacity: 0.55;
}

/* ── 分隔 ── */
.sep {
  display: flex;
  align-items: center;
  margin: 40rpx 0 36rpx;
}

.sep-line {
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.sep-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* ── 加入房间 ── */
.join-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.join-input {
  flex: 1;
  height: 92rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8ecf1;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  text-align: center;
  color: #333;
  box-sizing: border-box;
}

.join-input:focus {
  border-color: #667eea;
}

.btn-join {
  width: 180rpx;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 92rpx;
  height: 92rpx;
  padding: 0;
  background: linear-gradient(135deg, #11998e, #38ef7d);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(56,239,125,0.3);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-join::after {
  border: none;
}

.btn-join[disabled] {
  opacity: 0.55;
}

/* ── 规则提示 ── */
.rules-tip {
  margin-top: 32rpx;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
}

.rules-tip-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.8;
}

/* ── 头像选择器 ── */
.avatar-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.avatar-picker {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.avatar-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}

.picker-item {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  overflow: hidden;
  flex-shrink: 0;
}

.picker-item.selected {
  border-color: #667eea;
  box-shadow: 0 2rpx 12rpx rgba(102,126,234,0.3);
}

.picker-avatar {
  width: 100%;
  height: 100%;
}

.picker-custom-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #e8ecf1;
  border-radius: 14rpx;
  background: #f9f9fb;
  color: #666;
  font-size: 28rpx;
  padding: 0;
}

.picker-custom-btn::after {
  border: none;
}
