<!-- pages/room/room.wxml -->
<view class="container">

  <!-- 加载中 -->
  <view wx:if="{{isLoading}}" class="loading-wrapper">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载房间信息...</text>
  </view>

  <!-- 已结束的横幅 -->
  <view wx:if="{{!isLoading && isGameFinished}}" class="finished-banner">
    <text class="finished-icon">&#x1F3C6;</text>
    <text class="finished-text">游戏已结束</text>
  </view>

  <!-- 房间头部 -->
  <view wx:if="{{!isLoading}}" class="room-header">
    <view class="room-code-wrapper">
      <text class="room-code-label">房间号</text>
      <text class="room-code-value" bindtap="copyRoomCode">{{roomInfo.roomCode}}</text>
      <text class="room-code-tip">点击复制</text>
    </view>
    <view class="room-meta">
      <view class="meta-item">
        <text class="meta-count">{{players.length}}</text>
        <text class="meta-label">/ {{maxPlayers || roomInfo.maxPlayers || '?'}} 人</text>
      </view>
      <view class="meta-status {{isGameFinished ? 'status-finished' : 'status-playing'}}">
        <text>{{isGameFinished ? '已结束' : '进行中'}}</text>
      </view>
    </view>
  </view>

  <!-- 玩家横向一排 -->
  <view wx:if="{{!isLoading}}" class="players-strip">
    <block wx:for="{{sortedPlayers}}" wx:key="openid">
      <!-- 自己 -->
      <view wx:if="{{openid === myOpenId}}" class="player-cell self-cell">
        <view class="player-avatar-wrap self-avatar">
          <image src="{{avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill" class="player-avatar-img" />
          <text class="self-badge">我</text>
        </view>
        <text class="player-name">{{nickName || '等待'}}</text>
        <view class="player-score {{score > 0 ? 'score-positive' : score < 0 ? 'score-negative' : ''}}">{{score}}</view>
        <text class="creator-tag" wx:if="{{openid === roomInfo.creatorId}}">房主</text>
      </view>
      <!-- 其他人（可点击送分） -->
      <view 
        wx:else 
        class="player-cell other-cell {{isGameFinished ? 'disabled' : ''}}"
        data-index="{{index}}"
        data-openid="{{openid}}"
        data-nickname="{{nickName || '匿名用户'}}"
        bindtap="onPlayerTap"
        hover-class="cell-hover"
      >
        <view class="player-avatar-wrap">
          <image src="{{avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill" class="player-avatar-img" />
        </view>
        <text class="player-name">{{nickName || '等待'}}</text>
        <view class="player-score {{score > 0 ? 'score-positive' : score < 0 ? 'score-negative' : ''}}">{{score}}</view>
        <text class="creator-tag" wx:if="{{openid === roomInfo.creatorId}}">房主</text>
      </view>
    </block>
  </view>

  <!-- 送分记录区域（占位） -->
  <view wx:if="{{!isLoading}}" class="records-section">
    <view class="records-header">
      <text class="records-title">送分记录</text>
      <text class="records-empty" wx:if="{{!records || records.length === 0}}">暂无记录</text>
    </view>
    <view class="records-list" wx:if="{{records && records.length > 0}}">
      <view class="record-item" wx:for="{{records}}" wx:key="index">
        <image src="{{item.fromAvatar || '/images/default-avatar.svg'}}" mode="aspectFill" class="record-avatar" />
        <text class="record-name">{{item.fromName}}</text>
        <text class="record-arrow">→</text>
        <image src="{{item.toAvatar || '/images/default-avatar.svg'}}" mode="aspectFill" class="record-avatar" />
        <text class="record-name">{{item.toName}}</text>
        <text class="record-amount {{item.value > 0 ? 'score-positive' : 'score-negative'}}">{{item.value > 0 ? '+' : ''}}{{item.value}}</text>
        <text class="record-time">{{item.timeStr}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view wx:if="{{!isLoading}}" class="bottom-actions">
    <button 
      wx:if="{{isOwner && !isGameFinished}}"
      class="btn-settle" 
      bindtap="settleGame"
    >结算游戏</button>
    <button 
      wx:if="{{isGameFinished}}"
      class="btn-back" 
      bindtap="goBack"
    >返回首页</button>
    <button 
      wx:if="{{!isGameFinished}}"
      class="btn-share" 
      open-type="share"
    >邀请好友加入</button>
  </view>

  <!-- 送分弹窗 -->
  <view wx:if="{{showKeypad}}" class="modal-mask" catchtap="cancelSend">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">向 {{targetNickname}} 送分</text>
        <view class="modal-close" catchtap="cancelSend">
          <text>X</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="score-input-area">
          <input 
            class="score-input" 
            type="number"
            keyboard-type="number"
            placeholder="0"
            value="{{keypadValue}}"
            bindinput="onKeypadInput"
            focus="{{showKeypad}}"
            maxlength="5"
          />
          <text class="score-input-unit">分</text>
        </view>
        <view class="quick-amounts">
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="1">+1</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="5">+5</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="10">+10</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="50">+50</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="100">+100</view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn-cancel" catchtap="cancelSend">
          <text>取消</text>
        </view>
        <view class="modal-btn modal-btn-confirm" catchtap="confirmSend">
          <text>确认送出</text>
        </view>
      </view>
    </view>
  </view>
</view>
