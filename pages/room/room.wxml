<!-- pages/room/room.wxml -->
<wxs module="fmt">
module.exports = {
  score: function(v) {
    var n = v - 0;
    if (n !== n) return '0';
    if (n === 0) return '0';
    if (n > 0) return '+' + n;
    return '' + n;
  }
};
</wxs>
<view class="container">

  <!-- 加载中 -->
  <view wx:if="{{isLoading}}" class="loading-wrapper">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载房间信息...</text>
  </view>

  <!-- 房间信息卡：头部 + 玩家合并 -->
  <view wx:if="{{!isLoading}}" class="room-card">
    <view class="room-header">
      <view class="room-code-wrapper">
        <text class="room-code-label">房间号</text>
        <text class="room-code-value" bindtap="copyRoomCode">{{roomInfo.roomCode}}</text>
        <text class="room-code-tip" wx:if="{{!isGameFinished}}">点击复制</text>
      </view>
      <view class="room-meta">
        <view class="meta-item">
          <text class="meta-count">{{sortedPlayers.length}}</text>
          <text class="meta-label">/ {{maxPlayers || roomInfo.maxPlayers || '?'}} 人</text>
        </view>
        <view class="meta-status {{isGameFinished ? 'status-finished' : 'status-playing'}}">
          <text>{{isGameFinished ? '已结束' : '进行中'}}</text>
        </view>
      </view>
    </view>

    <!-- 玩家横向一排 -->
    <view class="players-strip">
    <block wx:for="{{sortedPlayers}}" wx:key="openid">
      <!-- 自己（点击弹出修改弹窗） -->
      <view 
        class="player-cell self-cell {{isGameFinished ? 'disabled' : ''}}"
        data-openid="{{item.openid}}"
        data-index="{{index}}"
        bindtap="onSelfTap"
        hover-class="{{isGameFinished ? 'none' : 'cell-hover'}}"
      >
        <view class="player-avatar-wrap self-avatar">
          <image src="{{item.avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill" class="player-avatar-img" />
          <text class="self-badge">我</text>
        </view>
        <view class="player-name-row">
          <image wx:if="{{item.openid === roomInfo.creatorId}}" class="creator-icon" src="/images/house-icon.svg" mode="aspectFit" />
          <text class="player-name">{{item.nickName || '等待'}}</text>
        </view>
        <view class="player-score {{item.score > 0 ? 'score-positive' : item.score < 0 ? 'score-negative' : 'score-zero'}}">{{fmt.score(item.score)}}</view>
      </view>
      <!-- 其他人（可点击送分） -->
      <view 
        wx:if="{{item.openid !== myOpenId}}"
        class="player-cell other-cell {{isGameFinished ? 'disabled' : ''}}"
        data-index="{{index}}"
        data-openid="{{item.openid}}"
        data-nickname="{{item.nickName || '匿名用户'}}"
        bindtap="onPlayerTap"
        hover-class="cell-hover"
      >
        <view class="player-avatar-wrap">
          <image src="{{item.avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill" class="player-avatar-img" />
        </view>
        <view class="player-name-row">
          <image wx:if="{{item.openid === roomInfo.creatorId}}" class="creator-icon" src="/images/house-icon.svg" mode="aspectFit" />
          <text class="player-name">{{item.nickName || '等待'}}</text>
        </view>
        <view class="player-score {{item.score > 0 ? 'score-positive' : item.score < 0 ? 'score-negative' : 'score-zero'}}">{{fmt.score(item.score)}}</view>
      </view>
    </block>
    <!-- 茶水系统玩家（靠右单独展示） -->
    <view wx:if="{{teaPlayer}}"
      class="player-cell tea-cell {{isGameFinished ? 'disabled' : ''}}"
      data-openid="{{teaPlayer.openid}}"
      data-nickname="{{teaPlayer.nickName}}"
      bindtap="onPlayerTap"
      hover-class="cell-hover"
    >
      <view class="player-avatar-wrap tea-avatar">
        <image src="{{teaPlayer.avatarUrl || '/images/tea-avatar.svg'}}" mode="aspectFill" class="player-avatar-img" />
      </view>
      <view class="player-name-row">
        <text class="player-name tea-name">{{teaPlayer.nickName}}</text>
      </view>
      <view class="player-score {{teaPlayer.score > 0 ? 'score-positive' : teaPlayer.score < 0 ? 'score-negative' : 'score-zero'}}">{{fmt.score(teaPlayer.score)}}</view>
    </view>
  </view>
  </view>

  <!-- 空状态提示 -->
  <view wx:if="{{!isLoading && !isGameFinished && (!records || records.length === 0)}}" class="empty-hint">
    <text class="empty-hint-text">点击其他玩家头像送分</text>
  </view>

  <!-- 送分记录区域（聊天对话风格） —— 仅进行中且有记录时显示 -->
  <view wx:if="{{!isLoading && !isGameFinished && records && records.length > 0}}" class="records-section">
    <scroll-view class="records-list" scroll-y>
      <view wx:for="{{records}}" wx:key="index" class="chat-row {{item.isLeft ? 'chat-left' : 'chat-right'}}">
        <block wx:if="{{item.isLeft}}">
          <view class="chat-bubble chat-bubble-left">
            <view class="chat-desc">
              <text class="chat-name-tag chat-name-me">我</text>
              <text class="chat-desc-text"> 向 </text>
              <text class="chat-name-tag chat-name-to">{{item.toName}}</text>
              <text class="chat-desc-text"> 送 </text>
              <text class="chat-value-inline">{{item.valueStr}}</text>
            </view>
          </view>
          <view class="chat-time-space">
            <text class="chat-time">{{item.timeStr}}</text>
          </view>
        </block>
        <block wx:else>
          <view class="chat-time-space">
            <text class="chat-time">{{item.timeStr}}</text>
          </view>
          <view class="chat-bubble chat-bubble-right">
            <view class="chat-desc">
              <text class="chat-name-tag chat-name-from">{{item.fromName}}</text>
              <text class="chat-desc-text"> 向 </text>
              <text class="chat-name-tag chat-name-me">我</text>
              <text class="chat-desc-text"> 送 </text>
              <text class="chat-value-inline">{{item.valueStr}}</text>
            </view>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- 底部操作区 -->
  <view wx:if="{{!isLoading}}" class="bottom-actions">
    <button 
      wx:if="{{isOwner && !isGameFinished}}"
      class="btn-settle" 
      bindtap="settleGame"
    >结束游戏</button>
    <button 
      wx:if="{{isGameFinished}}"
      class="btn-back" 
      bindtap="goBack"
    >返回首页</button>
    <button 
      wx:if="{{!isGameFinished}}"
      class="btn-share" 
      open-type="share"
    >邀请好友加入</button>
  </view>

  <!-- 送分弹窗 -->
  <view wx:if="{{showKeypad}}" class="modal-mask" catchtap="cancelSend">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">向 {{targetNickname}} 送分</text>
        <view class="modal-close" catchtap="cancelSend">
          <text>X</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="score-input-area">
          <input 
            class="score-input" 
            type="number"
            keyboard-type="number"
            placeholder="0"
            value="{{keypadValue}}"
            bindinput="onKeypadInput"
            focus="{{showKeypad}}"
            maxlength="5"
          />
          <text class="score-input-unit">分</text>
        </view>
        <view class="quick-amounts">
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="1">+1</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="5">+5</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="10">+10</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="50">+50</view>
          <view class="quick-btn" bindtap="setQuickAmount" data-amount="100">+100</view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn-cancel" catchtap="cancelSend">
          <text>取消</text>
        </view>
        <view class="modal-btn modal-btn-confirm" catchtap="confirmSend">
          <text>确认送出</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 修改个人信息弹窗 -->
  <view wx:if="{{showProfileEdit}}" class="modal-mask" catchtap="cancelProfileEdit">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改个人信息</text>
        <view class="modal-close" catchtap="cancelProfileEdit">
          <text>X</text>
        </view>
      </view>
      <view class="modal-body">
        <!-- 头像预览 -->
        <view class="edit-avatar-preview">
          <image src="{{editAvatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill" class="edit-avatar-img" />
        </view>
        <!-- 预设头像网格 -->
        <view class="preset-grid">
          <view 
            wx:for="{{presetAvatars}}" 
            wx:key="*this"
            class="preset-item {{editAvatarUrl === item ? 'preset-selected' : ''}}"
            data-url="{{item}}"
            bindtap="selectPresetAvatar"
          >
            <image src="{{item}}" mode="aspectFill" class="preset-avatar" />
          </view>
        </view>
        <!-- 使用微信头像 -->
        <button class="use-wechat-btn" open-type="chooseAvatar" bindchooseavatar="onChooseWechatAvatar">使用微信头像</button>
        <!-- 昵称输入 -->
        <view class="profile-edit-field">
          <text class="edit-label">昵称</text>
          <input 
            class="edit-input" 
            type="nickname"
            placeholder="输入昵称或使用微信昵称"
            value="{{editNickname}}"
            bindinput="onNicknameInput"
            bindblur="onNicknameConfirm"
            maxlength="10"
          />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn-cancel" catchtap="cancelProfileEdit">
          <text>取消</text>
        </view>
        <view class="modal-btn modal-btn-confirm" catchtap="confirmProfileEdit">
          <text>保存</text>
        </view>
      </view>
    </view>
  </view>
</view>
