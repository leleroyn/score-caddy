/* pages/room/room.wxss */

/* ========= 全局容器 ========= */
.container {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ========= 加载中 ========= */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 4px solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16px;
  font-size: 15px;
  color: #999;
}

/* ========= 房间信息卡 ========= */
.room-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* ========= 房间头部 ========= */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 16px 12px;
}

.room-code-wrapper {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.room-code-label {
  font-size: 13px;
  color: #999;
}

.room-code-value {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 3px;
}

.room-code-tip {
  font-size: 11px;
  color: #bbb;
}

.room-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.meta-item {
  display: flex;
  align-items: baseline;
}

.meta-count {
  font-size: 20px;
  font-weight: 700;
  color: #667eea;
}

.meta-label {
  font-size: 13px;
  color: #999;
}

.meta-status {
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
}

.status-playing {
  background: #e8f5e9;
  color: #2e7d32;
}

.status-finished {
  background: #fff3e0;
  color: #e65100;
}

/* ========= 玩家横向一排 ========= */
.players-strip {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 16rpx;
  background: #fff;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  border-top: 1rpx solid #f5f5f5;
}

.players-strip::-webkit-scrollbar {
  display: none;
}

.player-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 130rpx;
  flex-shrink: 0;
  position: relative;
}

.player-cell.disabled {
  opacity: 0.65;
}

.player-cell.self-cell {
  background: linear-gradient(135deg, #e8f0fe 0%, #f3e8ff 100%);
  border-radius: 16rpx;
  padding: 12rpx 8rpx 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.15);
}

.player-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.self-avatar {
  border: 3px solid #667eea;
}

.player-avatar-img {
  width: 100%;
  height: 100%;
}

.self-badge {
  position: absolute;
  bottom: -2px;
  right: -2px;
  background: #667eea;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  padding: 0 8rpx;
  border-radius: 12rpx;
  line-height: 1.5;
  border: 2px solid #fff;
}

.player-name {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: #333;
  margin-top: 6rpx;
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.player-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 6rpx;
  max-width: 150rpx;
}

.creator-icon {
  width: 14px;
  height: 14px;
  margin-right: 2rpx;
  flex-shrink: 0;
}



.player-score {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-top: 2rpx;
}

.player-score.score-zero {
  color: #333;
}

.player-score.score-positive {
  color: #e74c3c;
}

.player-score.score-negative {
  color: #2979ff;
}

.cell-hover {
  opacity: 0.7;
}

/* ========= 茶水系统玩家 ========= */
.tea-cell {
  margin-left: auto;
  flex-shrink: 0;
  padding: 12rpx 8rpx 8rpx;
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.15);
}

.tea-avatar {
  border: 3px solid #FFB74D;
}

.tea-name {
  color: #E65100;
  font-weight: 600;
}

/* ========= 空状态提示 ========= */
.empty-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-hint-text {
  font-size: 28rpx;
  color: #bbb;
}

/* ========= 送分记录（聊天对话风格） ========= */
.records-section {
  margin: 16rpx;
  background: #f0f2f5;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.records-empty {
  font-size: 24rpx;
  color: #bbb;
  padding: 40rpx 0;
  text-align: center;
}

.records-list {
  max-height: 600rpx;
  min-height: 120rpx;
}

.chat-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.chat-row:last-child {
  margin-bottom: 0;
}

/* 气泡 */
.chat-bubble {
  max-width: 65%;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
}

.chat-bubble-left {
  background: #ffffff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.chat-bubble-right {
  background: #95ec69;
  border-top-right-radius: 4rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.chat-desc {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.chat-desc-text {
  font-size: 26rpx;
  color: #666;
}

.chat-name-tag {
  font-size: 24rpx;
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.chat-name-to {
  background: rgba(102, 126, 234, 0.12);
  color: #667eea;
}

.chat-name-from {
  background: rgba(39, 174, 96, 0.12);
  color: #27ae60;
}

.chat-name-me {
  background: rgba(102, 126, 234, 0.12);
  color: #667eea;
  margin-left: 4rpx;
  margin-right: 4rpx;
}

.chat-value-inline {
  font-size: 32rpx;
  font-weight: 700;
  color: #e74c3c;
  margin-left: 8rpx;
  margin-right: 4rpx;
}

/* 时间 */
.chat-time-space {
  display: flex;
  align-items: flex-end;
  min-width: 80rpx;
  flex-shrink: 0;
}

.chat-time {
  font-size: 20rpx;
  color: #bbb;
  padding: 0 4rpx;
}

/* ========= 修改个人信息弹窗 ========= */
.edit-avatar-preview {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}

.edit-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3px solid #667eea;
}

.preset-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 20px;
}

.preset-item {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3px solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.preset-selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.1);
}

.preset-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.use-wechat-btn {
  display: block;
  width: 100%;
  text-align: center;
  padding: 12rpx 0;
  margin-bottom: 20px;
  font-size: 14px;
  color: #667eea;
  border: 1px dashed #667eea;
  border-radius: 10px;
  background: transparent;
  line-height: normal;
}

.use-wechat-btn::after {
  border: none;
}

.profile-edit-field {
  margin-bottom: 16px;
}

.edit-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #555;
  margin-bottom: 8px;
}

.edit-input {
  width: 100%;
  height: 44px;
  padding: 0 16px;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  font-size: 15px;
  color: #333;
  box-sizing: border-box;
}

/* ========= 底部操作区 ========= */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 20px calc(12px + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 10px;
  z-index: 100;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  margin: 0 16rpx;
  width: auto;
}

.bottom-actions .btn-settle,
.bottom-actions .btn-back,
.bottom-actions .btn-share {
  flex: 1;
  height: 48px;
  border: none;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 48px;
  padding: 0;
}

.bottom-actions .btn-settle::after,
.bottom-actions .btn-back::after,
.bottom-actions .btn-share::after {
  border: none;
}

.btn-settle {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  box-shadow: 0 4px 12px rgba(245, 87, 108, 0.35);
}

.btn-share {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  box-shadow: 0 4px 12px rgba(79, 172, 254, 0.3);
}

.btn-back {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.35);
}

/* ========= 送分弹窗 ========= */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background: #ffffff;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 24px 0;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1a1a2e;
}

.modal-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #666;
}

.modal-body {
  padding: 24px;
}

.score-input-area {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid #f0f0f0;
}

.score-input {
  font-size: 48px;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  width: 180px;
  line-height: 1.2;
}

.score-input-unit {
  font-size: 18px;
  color: #999;
  margin-left: 6px;
}

.quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
}

.quick-btn {
  width: 64px;
  height: 40px;
  border-radius: 10px;
  background: #f5f6fa;
  color: #555;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-btn:active {
  background: #e8ecf1;
}

.modal-footer {
  display: flex;
  padding: 16px 24px 24px;
  gap: 12px;
}

.modal-btn {
  flex: 1;
  height: 50px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
}

.modal-btn-cancel {
  background: #f5f6fa;
  color: #666;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.35);
}


