/* pages/room/room.wxss */

/* ========= 全局容器 ========= */
.container {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ========= 加载中 ========= */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 4px solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16px;
  font-size: 15px;
  color: #999;
}

/* ========= 游戏结束横幅 ========= */
.finished-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.finished-icon {
  font-size: 18px;
  margin-right: 6px;
}

.finished-text {
  font-size: 15px;
  font-weight: 600;
  color: #d35400;
}

/* ========= 房间头部 ========= */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 16px 12px;
  background: #ffffff;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
}

.room-code-wrapper {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.room-code-label {
  font-size: 13px;
  color: #999;
}

.room-code-value {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 3px;
}

.room-code-tip {
  font-size: 11px;
  color: #bbb;
}

.room-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.meta-item {
  display: flex;
  align-items: baseline;
}

.meta-count {
  font-size: 20px;
  font-weight: 700;
  color: #667eea;
}

.meta-label {
  font-size: 13px;
  color: #999;
}

.meta-status {
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
}

.status-playing {
  background: #e8f5e9;
  color: #2e7d32;
}

.status-finished {
  background: #fff3e0;
  color: #e65100;
}

/* ========= 玩家横向一排 ========= */
.players-strip {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 16rpx;
  background: #fff;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}

.players-strip::-webkit-scrollbar {
  display: none;
}

.player-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 130rpx;
  flex-shrink: 0;
  position: relative;
}

.player-cell.disabled {
  opacity: 0.65;
}

.player-cell.self-cell {
  background: linear-gradient(135deg, #e8f0fe 0%, #f3e8ff 100%);
  border-radius: 16rpx;
  padding: 12rpx 8rpx 8rpx;
}

.player-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.self-avatar {
  border: 3px solid #667eea;
}

.player-avatar-img {
  width: 100%;
  height: 100%;
}

.self-badge {
  position: absolute;
  bottom: -2px;
  right: -2px;
  background: #667eea;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  padding: 0 8rpx;
  border-radius: 12rpx;
  line-height: 1.5;
  border: 2px solid #fff;
}

.player-name {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: #333;
  margin-top: 6rpx;
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.player-score {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-top: 2rpx;
}

.player-score.score-positive {
  color: #e74c3c;
}

.player-score.score-negative {
  color: #27ae60;
}

.creator-tag {
  font-size: 18rpx;
  color: #e67e22;
  background: #fff3e0;
  padding: 1rpx 10rpx;
  border-radius: 6rpx;
  margin-top: 4rpx;
}

.cell-hover {
  opacity: 0.7;
}

/* ========= 送分记录 ========= */
.records-section {
  margin: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.records-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.records-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.records-empty {
  font-size: 24rpx;
  color: #bbb;
}

.records-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.record-name {
  font-size: 24rpx;
  color: #555;
  flex-shrink: 0;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-arrow {
  font-size: 24rpx;
  color: #ccc;
  flex-shrink: 0;
}

.record-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-left: auto;
  flex-shrink: 0;
}

.record-amount.score-positive {
  color: #e74c3c;
}

.record-amount.score-negative {
  color: #27ae60;
}

.record-time {
  font-size: 20rpx;
  color: #bbb;
  flex-shrink: 0;
  width: 80rpx;
  text-align: right;
}

/* ========= 底部操作区 ========= */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 20px calc(12px + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 10px;
  z-index: 100;
}

.bottom-actions .btn-settle,
.bottom-actions .btn-back,
.bottom-actions .btn-share {
  flex: 1;
  height: 48px;
  border: none;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 48px;
  padding: 0;
}

.bottom-actions .btn-settle::after,
.bottom-actions .btn-back::after,
.bottom-actions .btn-share::after {
  border: none;
}

.btn-settle {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  box-shadow: 0 4px 12px rgba(245, 87, 108, 0.35);
}

.btn-share {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  box-shadow: 0 4px 12px rgba(79, 172, 254, 0.3);
}

.btn-back {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.35);
}

/* ========= 送分弹窗 ========= */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background: #ffffff;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 24px 0;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1a1a2e;
}

.modal-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #666;
}

.modal-body {
  padding: 24px;
}

.score-input-area {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid #f0f0f0;
}

.score-input {
  font-size: 48px;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  width: 180px;
  line-height: 1.2;
}

.score-input-unit {
  font-size: 18px;
  color: #999;
  margin-left: 6px;
}

.quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
}

.quick-btn {
  width: 64px;
  height: 40px;
  border-radius: 10px;
  background: #f5f6fa;
  color: #555;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-btn:active {
  background: #e8ecf1;
}

.modal-footer {
  display: flex;
  padding: 16px 24px 24px;
  gap: 12px;
}

.modal-btn {
  flex: 1;
  height: 50px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
}

.modal-btn-cancel {
  background: #f5f6fa;
  color: #666;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.35);
}
